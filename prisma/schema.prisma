// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums stored as strings in SQLite
// UserRole: PATIENT, DOCTOR, ADMIN
// AppointmentStatus: PENDING, CONFIRMED, COMPLETED, CANCELLED
// AppointmentType: ONLINE, OFFLINE
// SeverityLevel: LOW, MEDIUM, HIGH, CRITICAL

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String?   // Optional for OAuth users
  name          String?
  role          String    @default("PATIENT")
  phone         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Password reset fields
  resetToken    String?
  resetTokenExpiry DateTime?

  // Location fields
  city          String?
  state         String?
  zipCode       String?
  latitude      Float?
  longitude     Float?

  // Emergency card fields
  bloodType              String?
  allergies              String?   // JSON array of strings
  emergencyContactName   String?
  emergencyContactPhone  String?

  // OAuth fields
  emailVerified DateTime?
  image         String?

  // Relations
  accounts      Account[]
  sessions      Session[]
  appointments  Appointment[]
  symptoms      SymptomLog[]
  medicalHistory MedicalHistory[]
  medicalDocuments MedicalDocument[]
  reviews       Review[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model SymptomLog {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  symptoms      String        // Array of symptoms reported (stored as JSON)
  description   String        // Detailed description from chat
  chatHistory   String        // Full chat conversation (stored as JSON)

  severity      String        @default("LOW")
  aiDiagnosis   String?       // AI-suggested conditions
  recommendation String?      // AI recommendation (see doctor, self-care, emergency)
  suggestedMedicines String?  // AI-suggested medicines with dosage (stored as JSON)

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Relations
  appointment   Appointment?

  @@map("symptom_logs")
}

model Appointment {
  id            String            @id @default(cuid())
  patientId     String
  patient       User              @relation(fields: [patientId], references: [id], onDelete: Cascade)

  doctorId      String?
  doctor        Doctor?           @relation(fields: [doctorId], references: [id])

  symptomLogId  String?           @unique
  symptomLog    SymptomLog?       @relation(fields: [symptomLogId], references: [id])

  appointmentDate DateTime
  appointmentTime String
  type          String            @default("OFFLINE")
  status        String            @default("PENDING")

  reason        String
  notes         String?

  // Notification tracking
  emailSent     Boolean           @default(false)
  smsSent       Boolean           @default(false)

  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@map("appointments")
}

model MedicalHistory {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  condition     String
  diagnosis     String?
  treatment     String?
  medications   String        // Array of medications (stored as JSON)

  diagnosedDate DateTime?
  notes         String?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("medical_history")
}

model Doctor {
  id            String    @id @default(cuid())
  name          String
  specialization String
  email         String    @unique
  phone         String

  experience    Int       // Years of experience
  location      String
  address       String?   // Full address
  latitude      Float?    // GPS coordinates for maps
  longitude     Float?    // GPS coordinates for maps
  city          String?
  state         String?
  zipCode       String?

  availableSlots String    // Available time slots (stored as JSON)
  isAvailable   Boolean   @default(true)

  // Additional info
  rating        Float?    @default(0)
  reviewCount   Int       @default(0)
  consultationFee Float?

  // Relations
  appointments  Appointment[]
  reviews       Review[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("doctors")
}

model MedicalDocument {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  title         String
  description   String?
  category      String    // LAB_REPORT, PRESCRIPTION, XRAY, CERTIFICATE, OTHER
  fileName      String
  fileUrl       String    // File path or URL
  fileSize      Int       // Size in bytes
  mimeType      String    // File MIME type

  uploadedDate  DateTime  @default(now())
  documentDate  DateTime? // Actual date of the document (e.g., test date)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("medical_documents")
}

model Review {
  id            String    @id @default(cuid())
  doctorId      String
  doctor        Doctor    @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  rating        Float     // 1-5 stars
  comment       String?

  // Rating categories
  professionalism Float?  // 1-5 rating for professionalism
  waitTime      Float?    // 1-5 rating for wait time
  bedsidemanner Float?    // 1-5 rating for bedside manner

  helpfulCount  Int       @default(0)  // Number of users who found this helpful

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("reviews")
}

