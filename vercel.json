{
  "buildCommand": "prisma generate && prisma db push --skip-generate && next build",
  "crons": [
    {
      "path": "/api/cron/weekly-digest",
      "schedule": "0 9 * * 1"
    },
    {
      "path": "/api/cron/daily-reminders",
      "schedule": "30 3 * * *"
    }
  ],
  "functions": {
    "pages/api/symptom-check/chat.ts": {
      "maxDuration": 60
    },
    "pages/api/symptom-check/analyze-image.ts": {
      "maxDuration": 60
    },
    "pages/api/medicine-checker.ts": {
      "maxDuration": 60
    },
    "pages/api/mood-insights.ts": {
      "maxDuration": 60
    },
    "pages/api/medical-records/ocr.ts": {
      "maxDuration": 60
    },
    "pages/api/cron/daily-reminders.ts": {
      "maxDuration": 60
    },
    "pages/api/health-chat.ts": {
      "maxDuration": 60
    },
    "pages/api/vitals/insights.ts": {
      "maxDuration": 60
    }
  }
}
